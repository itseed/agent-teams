{
  "autoCompactEnabled": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(tmux *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .team-state.md ]; then echo '=== TEAM STATE ===' && cat .team-state.md; else echo '[WARNING] .team-state.md not found — run start-team.sh first'; fi"
          }
        ]
      }
    ]
  }
}
